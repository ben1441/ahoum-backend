# Copy to .env for local development outside docker.
# docker-compose.yml provides its own values for the containerized stack.

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database / broker ---
DATABASE_URL=postgres://ahoum:ahoum@localhost:5432/ahoum
REDIS_URL=redis://localhost:6379/0

# --- Email ---
# consolemail:// prints emails to stdout (dev). For real SMTP use e.g.:
# EMAIL_URL=submission://user:password@smtp.example.com:587
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=Ahoum Events <no-reply@ahoum.com>

# --- Celery ---
# Set true to run tasks inline without a worker (local dev convenience).
CELERY_TASK_ALWAYS_EAGER=false

# --- OTP knobs ---
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
