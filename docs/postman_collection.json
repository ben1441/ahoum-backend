{
  "info": {
    "name": "Ahoum Events API",
    "description": "Events platform: auth + OTP, RBAC, search, enrollments. Set the `base_url` collection variable (default http://localhost:8000/api). The login requests auto-capture access/refresh tokens into variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "access", "value": "" },
    { "key": "refresh", "value": "" },
    { "key": "event_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (seeker)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"sup3rsecret!\",\n  \"role\": \"seeker\"\n}"
            }
          }
        },
        {
          "name": "Verify email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "description": "Read the 6-digit OTP from the worker/console logs."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/resend-otp",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"newuser@example.com\"\n}" }
          }
        },
        {
          "name": "Login (seeded seeker)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const b = pm.response.json();",
                  "  pm.collectionVariables.set('access', b.access);",
                  "  pm.collectionVariables.set('refresh', b.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seeker@demo.ahoum.com\",\n  \"password\": \"demopass123!\"\n}"
            }
          }
        },
        {
          "name": "Login (seeded facilitator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const b = pm.response.json();",
                  "  pm.collectionVariables.set('access', b.access);",
                  "  pm.collectionVariables.set('refresh', b.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"facilitator@demo.ahoum.com\",\n  \"password\": \"demopass123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const b = pm.response.json();",
                  "  pm.collectionVariables.set('access', b.access);",
                  "  if (b.refresh) pm.collectionVariables.set('refresh', b.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List / search events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": {
              "raw": "{{base_url}}/events/?q=yoga&location=&language=&ordering=starts_at",
              "host": ["{{base_url}}"],
              "path": ["events", ""],
              "query": [
                { "key": "q", "value": "yoga" },
                { "key": "location", "value": "" },
                { "key": "language", "value": "" },
                { "key": "starts_after", "value": "", "disabled": true },
                { "key": "starts_before", "value": "", "disabled": true },
                { "key": "ordering", "value": "starts_at" }
              ]
            }
          }
        },
        {
          "name": "Create event (facilitator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('event_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access}}" }
            ],
            "url": "{{base_url}}/events/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Evening Meditation\",\n  \"description\": \"Guided calm before sleep.\",\n  \"language\": \"english\",\n  \"location\": \"Online\",\n  \"starts_at\": \"2030-01-01T18:00:00Z\",\n  \"ends_at\": \"2030-01-01T19:00:00Z\",\n  \"capacity\": 2\n}"
            }
          }
        },
        {
          "name": "Retrieve event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/events/{{event_id}}/"
          }
        },
        {
          "name": "Update event (owner)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access}}" }
            ],
            "url": "{{base_url}}/events/{{event_id}}/",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Evening Meditation (updated)\"\n}" }
          }
        },
        {
          "name": "Delete event (owner)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/events/{{event_id}}/"
          }
        },
        {
          "name": "My events + counts (facilitator)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/events/mine/"
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll in event (seeker)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/events/{{event_id}}/enroll/"
          }
        },
        {
          "name": "Cancel enrollment (seeker)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": "{{base_url}}/events/{{event_id}}/cancel/"
          }
        },
        {
          "name": "My upcoming enrollments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": {
              "raw": "{{base_url}}/enrollments/?when=upcoming",
              "host": ["{{base_url}}"],
              "path": ["enrollments", ""],
              "query": [{ "key": "when", "value": "upcoming" }]
            }
          }
        },
        {
          "name": "My past enrollments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": {
              "raw": "{{base_url}}/enrollments/?when=past",
              "host": ["{{base_url}}"],
              "path": ["enrollments", ""],
              "query": [{ "key": "when", "value": "past" }]
            }
          }
        }
      ]
    }
  ]
}
